#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Uninstalling hbctool...${NC}"

pip uninstall -y hbctool 2>/dev/null || {
    echo -e "${YELLOW}hbctool not found or already uninstalled.${NC}"
}

echo -e "${GREEN}hbctool completely removed.${NC}"
exit 0
